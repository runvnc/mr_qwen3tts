# mr_qwen3tts - Qwen3-TTS plugin environment variables

# Backend selection: openai (default) | websocket | vllm
# openai = groxaxo OpenAI-FastAPI server (lowest latency, recommended)
# websocket = custom Qwen3-TTS WebSocket server
# vllm = vllm-omni HTTP API
MR_QWEN3TTS_BACKEND=openai

# groxaxo OpenAI-FastAPI server URL (for openai backend)
MR_QWEN3TTS_OPENAI_URL=http://localhost:8880

# Default voice name (for openai backend)
# Built-in voices: Vivian, Ethan, etc.
# Voice Library clones: clone:VoiceName
MR_QWEN3TTS_VOICE=Vivian

# Model name for API requests (for openai backend)
MR_QWEN3TTS_MODEL=qwen3-tts

# WebSocket server URL (for websocket backend)
MR_QWEN3TTS_WS_URL=ws://localhost:8765

# Voice Clone Configuration (for websocket backend)
MR_QWEN3TTS_REF_AUDIO=/path/to/reference.wav
MR_QWEN3TTS_REF_TEXT="The exact transcript of the reference audio"

# Language setting (default: Auto)
# Supported: Auto, Chinese, English, Japanese, Korean, German, French, Russian, Portuguese, Spanish, Italian
MR_QWEN3TTS_LANGUAGE=Auto

# Enable realtime streaming (streams text as LLM generates it)
# MR_QWEN3TTS_REALTIME_STREAM=1
